{
  "name": "seqrets",
  "version": "1.10.8",
  "codename": "Ignition",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "generate:version": "node scripts/generate-version.mjs",
    "build:crypto": "npm run build --workspace=@seqrets/crypto",
    "dev": "npm run generate:version && npm run build:crypto && next dev --port 9002",
    "build": "npm run generate:version && npm run build:crypto && next build",
    "start": "npm run generate:version && next start",
    "type-check": "npm run generate:version && tsc --noEmit",
    "test": "echo \"No test runner configured\" && exit 0",
    "security-audit": "npm audit",
    "security-audit:fix": "npm audit fix",
    "deps:outdated": "npm outdated",
    "deps:update": "npm update",
    "build:analyze": "ANALYZE=true npm run build",
    "desktop:dev": "npm run generate:version && npm run build:crypto && npm run tauri:dev:fresh --workspace=@seqrets/desktop",
    "desktop:build": "npm run generate:version && npm run build:crypto && npm run tauri:build --workspace=@seqrets/desktop",
    "bump": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.475.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.0",
    "qrcode": "^1.5.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@types/node": "20.19.35",
    "@types/qrcode": "^1.5.5",
    "@types/react": "npm:types-react@rc",
    "@types/react-dom": "npm:types-react-dom@rc",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "qs": "^6.14.1",
    "fast-xml-parser": "5.3.4",
    "dompurify": "^3.4.0",
    "postcss": "^8.5.10"
  }
}
